Subtask 2.2: Perform Live Linux Data Collection
Execute comprehensive live response collection:

# Create Linux collection script
cat > collect_linux_data.sh << 'EOF'
#!/bin/bash

# Create output directory
OUTPUT_DIR=~/linux_collection/$(date +%Y%m%d_%H%M%S)
mkdir -p $OUTPUT_DIR

echo "Starting Linux Live Response Collection..."

# System Information
echo "=== SYSTEM INFORMATION ===" > $OUTPUT_DIR/system_info.txt
uname -a >> $OUTPUT_DIR/system_info.txt
cat /etc/os-release >> $OUTPUT_DIR/system_info.txt
uptime >> $OUTPUT_DIR/system_info.txt
date >> $OUTPUT_DIR/system_info.txt

# Running Processes
echo "=== RUNNING PROCESSES ===" > $OUTPUT_DIR/processes.txt
ps aux --sort=-%cpu >> $OUTPUT_DIR/processes.txt
echo -e "\n=== PROCESS TREE ===" >> $OUTPUT_DIR/processes.txt
pstree -p >> $OUTPUT_DIR/processes.txt

# Network Information
echo "=== NETWORK CONNECTIONS ===" > $OUTPUT_DIR/network.txt
ss -tuln >> $OUTPUT_DIR/network.txt
echo -e "\n=== ESTABLISHED CONNECTIONS ===" >> $OUTPUT_DIR/network.txt
ss -tup >> $OUTPUT_DIR/network.txt
echo -e "\n=== ROUTING TABLE ===" >> $OUTPUT_DIR/network.txt
route -n >> $OUTPUT_DIR/network.txt

# File System Information
echo "=== MOUNTED FILESYSTEMS ===" > $OUTPUT_DIR/filesystem.txt
mount >> $OUTPUT_DIR/filesystem.txt
echo -e "\n=== DISK USAGE ===" >> $OUTPUT_DIR/filesystem.txt
df -h >> $OUTPUT_DIR/filesystem.txt

# User Information
echo "=== LOGGED IN USERS ===" > $OUTPUT_DIR/users.txt
who >> $OUTPUT_DIR/users.txt
echo -e "\n=== LAST LOGINS ===" >> $OUTPUT_DIR/users.txt
last -n 20 >> $OUTPUT_DIR/users.txt
echo -e "\n=== USER ACCOUNTS ===" >> $OUTPUT_DIR/users.txt
cat /etc/passwd >> $OUTPUT_DIR/users.txt

# System Logs (recent entries)
echo "=== SYSTEM LOGS ===" > $OUTPUT_DIR/logs.txt
tail -n 100 /var/log/syslog >> $OUTPUT_DIR/logs.txt 2>/dev/null || echo "Syslog not accessible" >> $OUTPUT_DIR/logs.txt
echo -e "\n=== AUTH LOGS ===" >> $OUTPUT_DIR/logs.txt
tail -n 50 /var/log/auth.log >> $OUTPUT_DIR/logs.txt 2>/dev/null || echo "Auth log not accessible" >> $OUTPUT_DIR/logs.txt

# Cron Jobs
echo "=== CRON JOBS ===" > $OUTPUT_DIR/cron.txt
crontab -l >> $OUTPUT_DIR/cron.txt 2>/dev/null || echo "No user crontab" >> $OUTPUT_DIR/cron.txt
echo -e "\n=== SYSTEM CRON ===" >> $OUTPUT_DIR/cron.txt
cat /etc/crontab >> $OUTPUT_DIR/cron.txt 2>/dev/null

# Environment Variables
echo "=== ENVIRONMENT VARIABLES ===" > $OUTPUT_DIR/environment.txt
env >> $OUTPUT_DIR/environment.txt

# Open Files
echo "=== OPEN FILES ===" > $OUTPUT_DIR/open_files.txt
lsof >> $OUTPUT_DIR/open_files.txt 2>/dev/null || echo "lsof not available" >> $OUTPUT_DIR/open_files.txt

# Memory Information
echo "=== MEMORY USAGE ===" > $OUTPUT_DIR/memory.txt
free -h >> $OUTPUT_DIR/memory.txt
echo -e "\n=== MEMORY MAP ===" >> $OUTPUT_DIR/memory.txt
cat /proc/meminfo >> $OUTPUT_DIR/memory.txt

echo "Linux collection completed. Data saved to: $OUTPUT_DIR"
EOF

chmod +x collect_linux_data.sh
./collect_linux_data.sh
