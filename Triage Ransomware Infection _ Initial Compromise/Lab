Subtask 4.2: Generate YARA Rule
# Create YARA rule for detection
cat > analysis/ransomware_detection.yar << 'EOF'
rule Ransomware_Detection {
    meta:
        description = "Detects ransomware based on lab analysis"
        author = "Security Analyst"
        date = "2024"
        
    strings:
        $ransom_note = "YOUR FILES HAVE BEEN ENCRYPTED"
        $bitcoin_demand = "Bitcoin to:"
        $contact_email = "@darkweb.onion"
        $file_extension = ".locked"
        $deadline = "72 hours"
        
    condition:
        any of them
}
EOF

echo "=== YARA RULE CREATED ==="
cat analysis/ransomware_detection.yar
