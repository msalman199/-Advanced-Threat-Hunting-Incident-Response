ls -la evidence/user_data/documents/ | grep "\.locked"
ls -la evidence/user_data/README_DECRYPT.txt
Task 3: Review Event Logs for Infection Vectors
Subtask 3.1: Analyze Authentication Logs
cd ~/ransomware_lab

# Examine authentication attempts
echo "=== AUTHENTICATION LOG ANALYSIS ==="
cat logs/auth_entries

# Extract failed login attempts
echo -e "\n=== FAILED LOGIN ANALYSIS ==="
grep "Failed password" logs/auth_entries | awk '{print $1, $2, $3, $9, $11}'

# Extract successful logins
echo -e "\n=== SUCCESSFUL LOGIN ANALYSIS ==="
grep "Accepted password" logs/auth_entries | awk '{print $1, $2, $3, $9, $11}'

# Identify privilege escalation
echo -e "\n=== PRIVILEGE ESCALATION ==="
grep "sudo" logs/auth_entries
Subtask 3.2: Analyze System Logs
# Examine system events
echo "=== SYSTEM LOG ANALYSIS ==="
cat logs/syslog_entries

# Look for suspicious services
echo -e "\n=== SUSPICIOUS SERVICES ==="
grep "malicious-service" logs/syslog_entries

# Check for scheduled tasks
echo -e "\n=== SCHEDULED TASK ANALYSIS ==="
grep "cron" logs/syslog_entries

# Network anomalies
echo -e "\n=== NETWORK ANOMALIES ==="
grep "SYN flooding\|large data transfer" logs/syslog_entries
