Network Indicators:
- Bitcoin Address: 1A2B3C4D5E6F7G8H9I0J
- Contact Email: decrypt@darkweb.onion

Behavioral Indicators:
- Mass file encryption
- Ransom note placement
- System service manipulation
EOF

cat analysis/ioc_report.txt
Subtask 2.3: Timeline Analysis
# Create timeline of file modifications
echo "=== FILE MODIFICATION TIMELINE ==="
find evidence/ -type f -exec stat -c "%Y %n" {} \; | sort -n | tail -10

# Analyze file creation patterns
